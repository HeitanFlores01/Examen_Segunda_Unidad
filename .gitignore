# Publicar salida web
*.[Pp]publicar.xml
*.azurePubxml
# TODO: Comenta la siguiente línea si quieres guardar la configuración de despliegue web.
# pero las cadenas de conexión a la base de datos (con posibles contraseñas) no estarán cifradas.
*.pubxml
*.publicarproyecto

# Configuración de publicación de la aplicación web de Microsoft Azure. Comente la siguiente línea si desea
# Compruebe la configuración de publicación de su aplicación web de Azure, pero la información confidencial está contenida.
# en estos scripts no estarán cifrados
Scripts de publicación/

# Paquetes NuGet
*.nupkg
# La carpeta de paquetes puede ignorarse debido a la restauración de paquetes.
**/paquetes/*
# excepto build/, que se utiliza como destino de MSBuild.
!**/packages/build/
# Descomente si es necesario, aunque generalmente se regenerará cuando sea necesario.
#!**/packages/repositories.config
# Los archivos project.json de NuGet v3 producen más archivos ignorables
*.nuget.props
*.nuget.targets

# Salida de compilación de Microsoft Azure
csx/
*.build.csdef

# Emulador de Microsoft Azure
ecf/
rcf/

# Directorios y archivos de paquetes de aplicaciones de la Tienda Windows
Paquetes de aplicaciones/
BundleArtifacts/
Paquete.StoreAssociation.xml
_pkginfo.txt

# Archivos de caché de Visual Studio
# Los archivos que terminan en .cache pueden ser ignorados
*.[Cc]ache
# pero mantén un registro de los directorios que terminan en .cache
!*.[Cc]ache/

# Otros
Bandeja del cliente/
~$*
*~
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings
node_modules/
orleans.codegen.cs

# Dado que existen múltiples flujos de trabajo, descomente la siguiente línea para ignorar bower_components.
# (https://github.com/github/gitignore/pull/1529#issuecomment-104372622)
#componentes_bower/

# Proyectos RIA/Silverlight
Código_generado/

# Copia de seguridad y archivos de informe de la conversión de un archivo de proyecto antiguo
# a una versión más reciente de Visual Studio. No se necesitan archivos de copia de seguridad.
# porque tenemos git ;-)
_UpgradeReport_Files/
Respaldo*/
Registro de actualización*.XML
Registro de actualización*.htm

